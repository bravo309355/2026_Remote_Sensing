# Shared ARIA defaults
APP_MODE=SIMULATION
SIMULATION_DATA=data/scenarios/fungwong_202511.json
TARGET_COUNTIES=花蓮縣,宜蘭縣
DEM_PATH=data/DEM_tawiwan_V2025.tif

# CWA credentials
CWA_API_KEY=
# Backward-compatible alias still supported by the code:
API_KEY_CWA=

# Terrain thresholds
SLOPE_THRESHOLD=30
ELEVATION_LOW=50
BUFFER_HIGH=500
COUNTY_BUFFER=1000

# Dynamic rainfall thresholds
RAIN_BUFFER_M=5000
WARNING_RAIN_MM=40
CRITICAL_RAIN_MM=80
LIVE_TIMEOUT_S=12

# Output locations
OUTPUT_DIR=outputs/aria_v3
SUBMISSION_DIR=submission/Homework-5
REBUILD_STATIC_BASELINE=0

# Bonus Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUEST_DELAY_S=1.5
