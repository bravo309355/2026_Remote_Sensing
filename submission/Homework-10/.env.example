# Week 10 Homework — ARIA v7.0 (Hualien × Typhoon Fung-wong)
# Copy this file to .env and fill in the secrets. The .env file is git-ignored.

# ── Study Area (Hualien / Matai'an watershed) ──────────────────────────
BBOX_WEST=121.28
BBOX_SOUTH=23.56
BBOX_EAST=121.52
BBOX_NORTH=23.76
TARGET_EPSG=32651
DEM_PATH=../../data/Hualien_dem_merge.tif
DEM_EPSG=3826

# ── Sentinel-1 SAR (Typhoon Fung-wong post-event) ──────────────────────
S1_COLLECTION=sentinel-1-rtc
S1_PRE_DATE=2025-10-30
S1_POST_DATE=2025-11-05
S1_ORBIT_STATE=ascending

# ── Sentinel-2 Optical (W9-style NDWI + cloud mask) ────────────────────
S2_COLLECTION=sentinel-2-l2a
S2_PRE_DATE=2025-10-16
S2_POST_DATE=2025-11-15
S2_PEAK_CLOUD_DATE=2025-11-02

# ── ARIA v7.0 Thresholds ───────────────────────────────────────────────
SAR_THRESHOLD=-18
NDWI_THRESHOLD=0.0
SLOPE_THRESHOLD=25
MIN_WATER_PIXELS=50

# ── Gemini API (for Task 4 AI Strategic Briefing) ──────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUEST_DELAY_S=3
GEMINI_RETRY_ATTEMPTS=3
